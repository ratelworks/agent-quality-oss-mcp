    "part": "https://quality.ratelworks.org/part/",

    "Act": "quality:Act",
    "Chapter": "quality:Chapter",
    "Section": "quality:Section",
    "Part": "quality:Part",
    "Article": "quality:Article",
    "Annex": "quality:Annex",
    "Document": "quality:Document",
    "Activity": "quality:Activity",
    "Material": "quality:Material",
    "Test": "quality:Test",
    "Criterion": "quality:Criterion",
    "Nonconformance": "quality:Nonconformance",
    "CorrectiveAction": "quality:CorrectiveAction",
    "Specification": "quality:Specification",
    "MaterialStandard": "quality:MaterialStandard",
    "Control": "quality:Control",
    "Cycle": "quality:Cycle",
    "Applicability": "quality:Applicability",
    "Source": "quality:Source",

    "Legislation": "schema:Legislation",
    "Action": "schema:Action",
    "DigitalDocument": "schema:DigitalDocument",
    "Thing": "schema:Thing",

    "delegates":      { "@id": "quality:delegates",      "@type": "@id", "@container": "@set" },
    "delegationOf":   { "@id": "quality:delegationOf",   "@type": "@id", "@container": "@set" },
    "concretizes":    { "@id": "quality:concretizes",    "@type": "@id", "@container": "@set" },
    "concretizedBy":  { "@id": "quality:concretizedBy",  "@type": "@id", "@container": "@set" },
    "references":     { "@id": "quality:references",     "@type": "@id", "@container": "@set" },
    "hasArticle":     { "@id": "quality:hasArticle",     "@type": "@id", "@container": "@set" },
    "hasChapter":     { "@id": "quality:hasChapter",     "@type": "@id", "@container": "@set" },
    "hasSection":     { "@id": "quality:hasSection",     "@type": "@id", "@container": "@set" },
    "hasAnnex":       { "@id": "quality:hasAnnex",       "@type": "@id", "@container": "@set" },
    "partOf":         { "@id": "quality:partOf",         "@type": "@id" },
    "specifies":      { "@id": "quality:specifies",      "@type": "@id", "@container": "@set" },
    "regulates":      { "@id": "quality:regulates",      "@type": "@id", "@container": "@set" },
    "regulatedBy":    { "@id": "quality:regulatedBy",    "@type": "@id", "@container": "@set" },
    "appliesTo":      { "@id": "quality:appliesTo",      "@type": "@id", "@container": "@set" },
    "applicableTo":   { "@id": "quality:applicableTo",   "@type": "@id", "@container": "@set" },
    "requires":       { "@id": "quality:requires",       "@type": "@id", "@container": "@set" },
    "requiresTest":   { "@id": "quality:requiresTest",   "@type": "@id", "@container": "@set" },
    "hasCriterion":   { "@id": "quality:hasCriterion",   "@type": "@id", "@container": "@set" },
    "verifies":       { "@id": "quality:verifies",       "@type": "@id", "@container": "@set" },
    "ifFails":        { "@id": "quality:ifFails",        "@type": "@id", "@container": "@set" },
    "correctedBy":    { "@id": "quality:correctedBy",    "@type": "@id", "@container": "@set" },
    "rootCauseOf":    { "@id": "quality:rootCauseOf",    "@type": "@id", "@container": "@set" },
    "usedIn":         { "@id": "quality:usedIn",         "@type": "@id", "@container": "@set" },
    "usesMaterial":   { "@id": "quality:usesMaterial",   "@type": "@id", "@container": "@set" },
    "inspectedBy":    { "@id": "quality:inspectedBy",    "@type": "@id", "@container": "@set" },
    "derivedFromSpec":{ "@id": "quality:derivedFromSpec","@type": "@id", "@container": "@set" },
    "legalBasis":     { "@id": "quality:legalBasis",     "@type": "@id", "@container": "@set" },
    "legalBasisOf":   { "@id": "quality:legalBasisOf",   "@type": "@id", "@container": "@set" },
    "guidedBy":       { "@id": "quality:guidedBy",       "@type": "@id", "@container": "@set" },
    "alternativeCycles": { "@id": "quality:alternativeCycles", "@type": "@id", "@container": "@set" },
    "appliesToActivities": { "@id": "quality:appliesToActivities", "@type": "@id", "@container": "@set" },
    "amendedTo":      { "@id": "quality:amendedTo",      "@type": "@id" },
    "interpretedBy":  { "@id": "quality:interpretedBy",  "@type": "@id", "@container": "@set" },
    "auditedBy":      { "@id": "quality:auditedBy",      "@type": "@id", "@container": "@set" },
    "informedBy":     { "@id": "quality:informedBy",     "@type": "@id", "@container": "@set" },
    "cited_in":       { "@id": "quality:citedIn",        "@type": "@id", "@container": "@set" },
    "involves":       { "@id": "quality:involves",       "@type": "@id", "@container": "@set" },
    "isPartOf":       { "@id": "schema:isPartOf",        "@type": "@id" },

    "docId": "quality:docId",
    "title": "schema:name",
    "alternativeNames": "schema:alternateName",
    "description": "schema:description",
    "articleNumber": "quality:articleNumber",
    "annexNumber": "quality:annexNumber",
    "delegationLevel": "quality:delegationLevel",
    "verificationStatus": "quality:verificationStatus",
    "legislationIdentifier": "schema:legislationIdentifier",
    "legislationDate": { "@id": "schema:legislationDate", "@type": "xsd:date" },
    "legislationType": "schema:legislationType",
    "legislationLegalForce": "schema:legislationLegalForce",
    "legislationPassedBy": { "@id": "schema:legislationPassedBy", "@type": "@id" },
    "jurisdiction": "schema:jurisdiction",
    "temporalCoverage": "schema:temporalCoverage",

    "trigger": "quality:trigger",
    "applicableWhen": { "@id": "quality:applicableWhen", "@type": "@json" },
    "exemptedWhen":   { "@id": "quality:exemptedWhen",   "@type": "@json" },
    "requiredFields": { "@id": "quality:requiredFields", "@type": "@json" },
    "reviewRules":    { "@id": "quality:reviewRules",    "@type": "@json" },
    "sections":       { "@id": "quality:sections",       "@type": "@json" },

    "cycle":          { "@id": "quality:cycle",          "@type": "@id" },
    "retention":      "quality:retention",
    "standardForm":   { "@id": "quality:standardForm",   "@type": "@json" },
    "relatedDocs":    { "@id": "quality:relatedDocs",    "@type": "@id", "@container": "@set" },

    "category":       "schema:category",
    "severity":       "quality:severity",
    "threshold":      "quality:threshold",
    "thresholdUnit":  "quality:thresholdUnit",
    "testMethod":     "quality:testMethod",
    "testFrequency":  "quality:testFrequency",
    "acceptanceLimit":{ "@id": "quality:acceptanceLimit","@type": "@json" },
    "tolerance":      { "@id": "quality:tolerance",      "@type": "@json" },
    "specGrade":      "quality:specGrade",
    "materialClass":  "quality:materialClass",
    "controlLevel":   "quality:controlLevel",

    "slug":           "quality:slug",
    "label":          "schema:name",
    "name":           "schema:name",
    "publishedBy":    "schema:publisher",
    "sourceUrl":      "schema:url",
    "fetchedAt":      "quality:fetchedAt",
    "licenseHint":    "quality:licenseHint",
    "searchKeywords": { "@id": "quality:searchKeywords", "@container": "@set" },
    "annexReference": { "@id": "quality:annexReference", "@type": "@id", "@container": "@set" },
    "annexKind":      "quality:annexKind",
    "amendmentHistory": { "@id": "quality:amendmentHistory", "@type": "@json" },
    "latestAmendment":  { "@id": "quality:latestAmendment",  "@type": "@json" },
    "constructionRelevance": "quality:constructionRelevance",
    "userPersona":    { "@id": "quality:userPersona", "@container": "@set" },
    "userVisible":    "quality:userVisible",
    "isAppendix":     "quality:isAppendix",
    "chapterNumber":  "quality:chapterNumber",
    "defaultIntervalDays": "quality:defaultIntervalDays",

    "legalBasisExternal":     { "@id": "quality:legalBasisExternal",     "@type": "xsd:string", "@container": "@set" },
    "legalBasisExternalNote": "quality:legalBasisExternalNote",

    "validation":    { "@id": "quality:validation",    "@type": "@json" },
    "externalRef":   { "@id": "quality:externalRef",   "@type": "@json" },
    "_meta":         { "@id": "quality:meta",          "@type": "@json" }
  }
