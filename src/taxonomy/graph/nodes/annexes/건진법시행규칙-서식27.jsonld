  "annexNumber": "27",
  "annexKind": "서식",
  "title": "건설엔지니어링(계약체결, 계약변경, 준공)통보",
  "partOf": "act:건설기술진흥법시행규칙",
  "verificationStatus": "verified",
  "legislationIdentifier": "건설기술 진흥법 시행규칙",
  "jurisdiction": "KR",
