  "title": "과태료의 부과기준(제121조제1항 관련)",
  "partOf": "act:건설기술진흥법시행령",
  "verificationStatus": "verified",
  "legislationIdentifier": "건설기술 진흥법 시행령",
  "jurisdiction": "KR",
  "constructionRelevance": "high",
  "userVisible": true,
